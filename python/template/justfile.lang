# Python overlay verbs — picked up by the base justfile's `import?`. Base
# verbs (lint, adr) live in justfile.base; never add them here.

# Run the test suite.
test *args:
    uv run pytest {{ args }}

# Type-check the project.
typecheck:
    uv run pyright

# Format Python sources with ruff.
format *args:
    uv run ruff format {{ args }}

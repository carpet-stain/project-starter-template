name: Lint

# The base lint workflow: language-agnostic linters only, selected via the
# lefthook `base` tag. A language overlay never touches this file — it ships
# its own workflow (e.g. test.yml) running its own tag slice with its own
# toolchain. Disjoint file ownership by design; see ADR-0020 in the template's
# source repo.
on:
  pull_request:
    types: [opened, reopened, synchronize, ready_for_review]
    branches: ["[[ protected_branch ]]"]

permissions:
  contents: read

concurrency:
  group: lint-${{ github.ref }}
  cancel-in-progress: true

jobs:
  lint:
    name: lint
    runs-on: ubuntu-latest
    # Draft PRs open early and take WIP pushes; a skipped-via-if job reads as
    # passing to required-status-check branch protection, not failing, so this
    # stays quiet until ready_for_review re-triggers it — same job-level gate
    # as pr-guards.yml.
    if: github.event.pull_request.draft == false
    steps:
      - uses: actions/checkout@v4

      # Portable toolchain, no Homebrew (#276): a bootstrapped repo has no
      # Homebrew tie, so install each linter its native way. markdownlint-cli2,
      # prettier, and lefthook itself are npm packages; just and the Go tools
      # (actionlint, yamlfmt) come from a setup action and pinned release
      # binaries. `just lint` still drives the shared lefthook, so CI and local
      # can't drift.
      - uses: actions/setup-node@v4
        with:
          node-version: lts/*
      - name: Install Node lint tools
        run: npm install --global lefthook markdownlint-cli2 prettier

      - uses: extractions/setup-just@v3

      - name: Install actionlint and yamlfmt
        env:
          ACTIONLINT_VERSION: "1.7.12"
          YAMLFMT_VERSION: "0.21.0"
        run: |
          curl -fsSL "https://github.com/rhysd/actionlint/releases/download/v${ACTIONLINT_VERSION}/actionlint_${ACTIONLINT_VERSION}_linux_amd64.tar.gz" \
            | sudo tar -xz -C /usr/local/bin actionlint
          curl -fsSL "https://github.com/google/yamlfmt/releases/download/v${YAMLFMT_VERSION}/yamlfmt_${YAMLFMT_VERSION}_Linux_x86_64.tar.gz" \
            | sudo tar -xz -C /usr/local/bin yamlfmt

      # `just lint` wraps `lefthook run pre-commit --all-files` — the same
      # entry point contributors run, here scoped to the base-owned jobs via
      # their lefthook tag. Locally (no tag filter) the full union runs on
      # every commit.
      - name: Run lint/format checks
        run: just lint --tag base --no-tty

# git-cliff configuration — https://git-cliff.org/docs/configuration

[changelog]
header = """
# Changelog

All notable changes to this project, generated from Conventional Commits.
"""
body = """
{% raw %}{% if version %}\
    ## [{{ version | trim_start_matches(pat="v") }}] - {{ timestamp | date(format="%Y-%m-%d") }}
{% else %}\
    ## [unreleased]
{% endif %}\
{% for group, commits in commits | group_by(attribute="group") %}
    ### {{ group | striptags | trim | upper_first }}
    {% for commit in commits %}
        - {% if commit.scope %}*({{ commit.scope }})* {% endif %}\
            {% if commit.breaking %}[**breaking**] {% endif %}\
            {{ commit.message | upper_first }}\
            {% if commit.remote.pr_number %} ([#{{ commit.remote.pr_number }}](<REPO>/pull/{{ commit.remote.pr_number }})){% endif %}\
    {% endfor %}
{% endfor %}\n{% endraw %}
"""
trim = true
render_always = true
postprocessors = [
  { pattern = '<REPO>', replace = "https://github.com/[[ github_owner ]]/[[ github_repo ]]" },
]

# PR links are resolved live via GitHub's API (commit -> PR association is
# tracked server-side and survives rebase-merge's SHA rewrite), not by
# parsing "(#N)" out of the commit message. Needs a token for reasonable
# rate limits: pass via GITHUB_TOKEN env var or --github-token, never in
# this file (see AGENTS.md's Credentials/Releases sections).
[remote.github]
owner = "[[ github_owner ]]"
repo = "[[ github_repo ]]"

[git]
conventional_commits = true
filter_unconventional = true
require_conventional = false
split_commits = false
commit_preprocessors = [
  # Strip any legacy "(#N)" text some commits may already carry, so the
  # link above — resolved via [remote.github], not this text — isn't
  # duplicated.
  { pattern = '(?m)\s*\((\w+\s)?#[0-9]+\)$', replace = "" },
]
protect_breaking_commits = false
commit_parsers = [
  { message = "^feat", group = "<!-- 0 -->Features" },
  { message = "^fix", group = "<!-- 1 -->Bug Fixes" },
  { message = "^refactor", group = "<!-- 2 -->Refactor" },
  { message = "^doc", group = "<!-- 3 -->Documentation" },
  { message = "^perf", group = "<!-- 4 -->Performance" },
  { message = "^style", group = "<!-- 5 -->Styling" },
  { message = "^test", group = "<!-- 6 -->Testing" },
  { message = "^build", group = "<!-- 7 -->Build" },
  { message = "^ci", group = "<!-- 8 -->CI" },
  { message = "^chore\\(release\\)", skip = true },
  { message = "^chore\\(deps.*\\)", skip = true },
  { message = "^chore", group = "<!-- 9 -->Chore" },
  { body = ".*security", group = "<!-- 10 -->Security" },
  { message = "^revert", group = "<!-- 11 -->Revert" },
  # Drop anything without a standard type (old pre-convention commits).
  { message = ".*", skip = true },
]
filter_commits = false
fail_on_unmatched_commit = false
use_branch_tags = false
topo_order = false
topo_order_commits = true
sort_commits = "oldest"
recurse_submodules = false
